      "source": [
        "array = [\"水\",\"金\",\"地\",\"火\",\"木\",\"土\",\"天\",\"海\",\"冥\"]\n",
        "\n",
        "#forを使った処理\n",
        "for planet in array:\n",
        "  print(planet)\n",
        "\n",
        "\n",
        "#whileを使った処理\n",
        "i = 0\n",
        "\n",
        "while i != 8:\n",
        "  print(array[i])\n",
        "  i = i + 1\n",
        "\n",
        "  if i == 8:\n",
        "   print(array[i])\n",
        "   break\n",
        "\n",
        ""
